doctype html
html
  head
    title Customers
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
  body
    .container.mt-5
      h1.mb-4 Customer List

      a.btn.btn-primary.mb-3(href="/addcustomer") Add New Customer

      table.table.table-bordered.table-striped
        thead
          tr
            th ID
            th First Name
            th Last Name
            th Email
            th Phone
        tbody
          each customer in customers
            tr
              td= customer.id
              td= customer.firstname
              td= customer.lastname
              td= customer.email
              td= customer.phone