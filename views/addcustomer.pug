doctype html
html
  head
    title Add Customer
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
  body
    .container.mt-5
      h1.mb-4 Add New Customer

      form(action="/addcustomer" method="POST")
        .mb-3
          label.form-label First Name
          input.form-control(type="text" name="firstname" required)

        .mb-3
          label.form-label Last Name
          input.form-control(type="text" name="lastname" required)

        .mb-3
          label.form-label Email
          input.form-control(type="email" name="email" required)

        .mb-3
          label.form-label Phone
          input.form-control(type="text" name="phone" required)

        button.btn.btn-success(type="submit") Add Customer
        a.btn.btn-secondary.ms-2(href="/customers") Back